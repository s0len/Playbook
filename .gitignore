# Cursor files
.cursor/mcp.json
.cursor/

# General files to ignore
.DS_Store
node_modules/
*.log

# Environment files
.env
.env.local
**/.env
**/.env.local
**/.env.*
# But allow .env.example template files (they don't contain secrets)
!**/.env.example
!.env.example 

# Python files to ignore
__pycache__/
*.pyc
*.egg-info/
.venv/
.ruff_cache/

# Logs and command output
sport.log
playbook.log
*.log.previous
*_output.txt

# Build and docs output
openapi.json
site/
package-lock.json

# Temporary scripts (auto-claude artifacts)
qa_*.py
verify_*.py
validate_*.py
integration_test*.py
code_quality_check.py
/test_*.py

# Temporary verification/investigation docs
*-verification*.md
INVESTIGATION.md
REFACTORING_SUMMARY.md
DOCKER_VERIFICATION.md
VERIFICATION.md
linting_report.md
AGENTS.md

.auto-claude/*
!.auto-claude/.env.example
.worktrees
.vscode/

# Auto Claude data directory
.auto-claude/
.auto-claude-security.json
.auto-claude-status

# Playbook cache (accidentally created inside repo)
${CACHE_DIR:-/var/cache/playbook}/
